# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Локально (docker-compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=cargobot
POSTGRES_PASSWORD=cargobot
POSTGRES_DB=cargobot
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Render / Railway (managed) ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# REDIS_URL=redis://default:pass@host:6379

# Демо-заявки, пока нет cookie бирж (true для первого деплоя)
ENABLE_DEMO_SOURCE=false

# Scheduler (minutes)
SCHEDULER_INTERVAL_MIN=10
SCHEDULER_INTERVAL_MAX=20
SOURCE_RETRY_ATTEMPTS=3
SOURCE_RETRY_DELAY_SEC=5

# ATI.SU — реальный webapi (POST /webapi/v1.0/loads/search)
ATI_SU_URL=https://loads.ati.su/
ATI_SU_API_URL=https://loads.ati.su/webapi/v1.0/loads/search
# Гео-ID: 50 = Китай, 10 = Казахстан (type 0 = страна). Меняйте под нужное направление.
ATI_SU_FROM_GEO_ID=50
ATI_SU_TO_GEO_ID=10
ATI_SU_ITEMS_PER_PAGE=10
# Cookie из DevTools после логина (обязательно sid=...). Протухает — обновлять периодически.
ATI_SU_COOKIE=
# Альтернатива cookie: автологин через форму id.ati.su (рекомендуется)
ATI_SU_LOGIN=
ATI_SU_PASSWORD=
ATI_SU_LOGIN_URL=https://id.ati.su/login/
# Через сколько минут принудительно перелогиниваться
ATI_SU_SESSION_TTL_MIN=60
# Опционально: полный JSON payload из DevTools (переопределяет from/to)
ATI_SU_SEARCH_PAYLOAD=

# Deliver.kz — cookie из DevTools после логина
DELIVER_KZ_URL=https://deliver.kz/ru/cargo
DELIVER_KZ_API_URL=
DELIVER_KZ_COOKIE=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000

# Logging
LOG_LEVEL=INFO
