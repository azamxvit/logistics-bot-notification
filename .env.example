# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Локально (docker-compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=cargobot
POSTGRES_PASSWORD=cargobot
POSTGRES_DB=cargobot
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Render / Railway (managed) ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# REDIS_URL=redis://default:pass@host:6379

# Демо-заявки, пока нет cookie бирж (true для первого деплоя)
ENABLE_DEMO_SOURCE=false

# Scheduler (minutes)
SCHEDULER_INTERVAL_MIN=10
SCHEDULER_INTERVAL_MAX=20
SOURCE_RETRY_ATTEMPTS=3
SOURCE_RETRY_DELAY_SEC=5

# Parsers — cookie из DevTools после логина на бирже
ATI_SU_URL=https://loads.ati.su/
ATI_SU_API_URL=
ATI_SU_COOKIE=
DELIVER_KZ_URL=https://deliver.kz/ru/cargo
DELIVER_KZ_API_URL=
DELIVER_KZ_COOKIE=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000

# Logging
LOG_LEVEL=INFO
